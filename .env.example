# ============================================================
#  E-Sport Information Collection — 환경변수 템플릿
#  이 파일은 git에 커밋됩니다. 실제 값은 절대 입력하지 마세요.
#  실제 값은 .env (로컬) 또는 Vercel 환경변수에 설정합니다.
# ============================================================

# ── 데이터베이스 ──────────────────────────────────────────
# Neon PostgreSQL (https://neon.tech) — 무료 플랜: 0.5GB, 최대 10 동시 연결
# connection_limit=5: Vercel 서버리스 연결 풀 제한 (연결 고갈 방지)
# Vercel에서는 반드시 Pooler 엔드포인트 사용 권장 (Neon Dashboard → Connection pooling)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&connection_limit=5&pool_timeout=20"

# ── 관리자 계정 ────────────────────────────────────────────
# ⚠️ 절대 소스 코드에 직접 입력하지 마세요 (GitHub 공개 레포 노출 위험)
# 여러 관리자 계정은 쉼표(,)로 구분합니다 (공백 무관)
# 이 이메일들로 로그인하면 자동으로 ADMIN 권한이 부여됩니다
ADMIN_EMAILS="admin1@gmail.com,admin2@gmail.com"

# ── NextAuth ──────────────────────────────────────────────
# 실제 배포 도메인으로 변경 (localhost는 개발 전용)
NEXTAUTH_URL="https://your-domain.vercel.app"
# openssl rand -base64 32 로 생성
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_64_CHAR_STRING"

# ── Google OAuth ─────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="REPLACE.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="REPLACE"

# ── OpenAI ───────────────────────────────────────────────
# https://platform.openai.com/api-keys
# 💰 요금: GPT-4o-mini 기준 약 $0.15/1M 토큰 (매우 저렴)
OPENAI_API_KEY="sk-proj-REPLACE"

# ── LangSmith (AI 트레이싱 — 선택사항) ──────────────────
# https://smith.langchain.com → Settings → API Keys
# 💰 요금: 무료 티어 50만 트레이스/월, 이후 $39/월
# ⚠️ PIPA 주의: 활성화 시 AI 채팅 메시지가 LangSmith(미국)로 전송됩니다.
#   개인정보처리방침에 LangSmith 위탁 고지 필요 (이미 반영됨).
#   프로덕션에서 비활성화하려면 LANGCHAIN_TRACING_V2=false 설정.
LANGCHAIN_API_KEY="lsv2_pt_REPLACE"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_TRACING_V2="false"  # false 권장 (프로덕션 PIPA 준수)

# ── LoL Esports API ──────────────────────────────────────
# 비공식 공개 API — 상업적 사용 불가, 언제든 차단 위험 있음
# Neon/Vercel 대시보드에서 이 값을 반드시 설정해야 합니다 (코드 하드코딩 금지)
LOL_ESPORTS_API_KEY="REPLACE_WITH_LOL_ESPORTS_API_KEY"

# ── Upstash Redis (Rate Limiting) ──────────────────────────
# https://console.upstash.com → Redis → Create DB (Seoul/Singapore)
# 💰 요금: 무료 플랜 10,000 req/일
UPSTASH_REDIS_REST_URL="https://REPLACE.upstash.io"
UPSTASH_REDIS_REST_TOKEN="REPLACE"

# ── Sentry (에러 모니터링) ──────────────────────────────────
# https://sentry.io → Projects → Create Project (Next.js)
# 💰 요금: 무료 플랜 5,000 에러/월
# 클라이언트 에러 리포팅 (브라우저 번들에 포함됨 — 의도적 공개)
NEXT_PUBLIC_SENTRY_DSN="https://REPLACE@o0.ingest.sentry.io/0"
# 소스맵 업로드용 (선택사항 — Vercel 환경변수에도 설정해야 빌드 시 적용됨)
# https://sentry.io → Settings → Auth Tokens 에서 발급
SENTRY_ORG="your-sentry-org-slug"
SENTRY_PROJECT="your-sentry-project-slug"
SENTRY_AUTH_TOKEN="sntrys_REPLACE"

# ── Cron Job 인증 ─────────────────────────────────────────
# openssl rand -hex 32 로 생성한 강한 랜덤 시크릿 사용
# Vercel 환경변수에도 동일하게 설정 필요
CRON_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"

# ── Cloudinary (이미지 업로드) ────────────────────────────
# https://cloudinary.com → 가입 후 Dashboard에서 확인
# 💰 요금: 무료 플랜 25GB 저장 + 25GB 전송/월 (이 프로젝트에 충분)
# 가입 후 Settings → API Keys 에서 확인
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Pusher (실시간 경매 — 경매장 오픈 시 활성화) ─────────
# https://dashboard.pusher.com → 앱 생성 후 입력
# 💰 요금: Sandbox 무료 (100 연결, 20만 메시지/일)
# PUSHER_APP_ID=""
# PUSHER_SECRET=""
# NEXT_PUBLIC_PUSHER_KEY=""
# NEXT_PUBLIC_PUSHER_CLUSTER="ap3"
