
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth Models ---
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // USER, ADMIN

  // Game Data
  gp            Int       @default(100) // Game Points

  accounts      Account[]
  sessions      Session[]

  userTeams     UserTeam[]
  inventory     UserInventory[]
  predictions   MatchPrediction[]
  lckPredictions LckPrediction[]
  cosmeticItems UserCosmeticItem[]
  userStickers  UserSticker[]
  profile       UserProfile?
  questProgress UserQuestProgress[]
  quizAnswers   UserDailyQuizAnswer[]
  following     Follows[] @relation("Follower")
  followedBy    Follows[] @relation("Following")
  posts         Post[]
  comments      Comment[]
  postLikes     PostLike[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ✅ M-9 수정: 랭킹 정렬 최적화 인덱스 (gp DESC 풀스캔 방지)
  @@index([gp])
}

model Follows {
  followerId  String
  follower    User   @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  followingId String
  following   User   @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
}

// --- Core Game Data Models ---

model Team {
  id           String   @id @default(uuid())
  code         String   @unique // T1, GEN, HLE, etc. (Source of Truth)
  name         String   // T1, Gen.G
  shortName    String?  // T1, GEN
  logoUrl      String?
  primaryColor String?
  
  players      Player[]
  
  homeMatches  Match[] @relation("HomeTeam")
  awayMatches  Match[] @relation("AwayTeam")
  wonMatches   Match[] @relation("WinnerTeam")
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Player {
  id          String   @id @default(uuid())
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id])
  
  name        String   // Faker
  realName    String?  // Lee Sang-hyeok
  position    String   // TOP, JUG, MID, ADC, SUP
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  
  basePrice   Int      @default(10)
  
  // Aggregated Stats (from CSV)
  stats       Json?    // { kda: 3.5, dpm: 500, ... }
  
  performances PlayerPerformance[]
  userTeamPlayers UserTeamPlayer[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Match {
  id          String   @id @default(uuid())
  season      String   // 2026-SPRING
  round       Int      // 1, 2, 3...
  matchDate   DateTime // Scheduled Time (UTC)
  
  status      String   @default("SCHEDULED") // SCHEDULED, COMPLETED
  leagueType  String   @default("REAL") // REAL, SIMULATION
  
  winnerId    String?
  winner      Team?    @relation("WinnerTeam", fields: [winnerId], references: [id])
  
  team1Id     String
  team1       Team     @relation("HomeTeam", fields: [team1Id], references: [id])
  team1Score  Int      @default(0)
  
  team2Id     String
  team2       Team     @relation("AwayTeam", fields: [team2Id], references: [id])
  team2Score  Int      @default(0)
  
    // Removed duplicate winnerId
  
  // Detailed Results (JSON for flexibility: bans, towers, dragons)
  details     Json?
  
  playerPerformances PlayerPerformance[]
  predictions        MatchPrediction[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlayerPerformance {
  id          String   @id @default(uuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  playerId    String
  // ✅ M-16 수정: Player 삭제 시 FK 오류 방지 — Restrict로 명시 (선수 삭제 전 퍼포먼스 데이터 정리 필요)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Restrict)
  
  // Game Stats
  kills       Int      @default(0)
  deaths      Int      @default(0)
  assists     Int      @default(0)
  cs          Int      @default(0)
  visionScore Int      @default(0)
  damage      Int      @default(0)
  
  fantasyPoints Float  @default(0)
  
  createdAt   DateTime @default(now())
}

// --- User Gameplay Models ---

model UserTeam {
  id          String   @id @default(uuid())
  userId      String   
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        String   @default("REAL") // REAL, SIMULATION
  
  name        String
  totalPoints Float    @default(0)
  budget      Int      @default(100) // Salary Cap
  isFinalized Boolean  @default(false)
  
  roster      UserTeamPlayer[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, type])
}

model UserTeamPlayer {
  id          String   @id @default(uuid())
  userTeamId  String
  userTeam    UserTeam @relation(fields: [userTeamId], references: [id], onDelete: Cascade)
  
  playerId    String
  // ✅ M-16 수정: Player 삭제 시 FK 오류 방지
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Restrict)
  position    String // Slot position
  isCaptain   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
}

// --- Shop Models ---

model ShopItem {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Int
  type        String   // CARD_PACK, ITEM
  imageUrl    String?
  
  createdAt   DateTime @default(now())
}

model UserInventory {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  itemId      String?
  itemType    String   // CARD, ITEM
  
  // If Card
  playerId    String?
  grade       String?  // NORMAL, RARE, EPIC, LEGEND
  
  createdAt   DateTime @default(now())
}

// --- Historical Stats Models (For Info Tab) ---

model HistoricalTeamStat {
  id          String   @id @default(uuid())
  teamName    String
  year        Int
  tournament  String
  
  games       Int      @default(0)
  wins        Int      @default(0)
  losses      Int      @default(0)
  
  totalKills  Int      @default(0)
  totalDeaths Int      @default(0)
  totalAssists Int     @default(0)
  totalDamage BigInt   @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([teamName, year, tournament])
}

model HistoricalPlayerStat {
  id          String   @id @default(uuid())
  playerName  String
  teamName    String
  position    String
  year        Int
  tournament  String
  
  games       Int      @default(0)
  wins        Int      @default(0)
  losses      Int      @default(0)
  
  totalKills  Int      @default(0)
  totalDeaths Int      @default(0)
  totalAssists Int     @default(0)
  
  averageKDA  Float    @default(0)
  averageDPM  Float    @default(0)
  averageVisionScore Float @default(0)
  
  totalDamage BigInt   @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  @@unique([playerName, year, tournament])
}

model MatchPrediction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  type        String   // WINNER
  target      String   // TeamCode
  
  isProcessed Boolean  @default(false)
  isCorrect   Boolean?
  pointsEarned Int     @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, matchId, type])
}

// ─────────────────────────────────────────────
// QUEST & ACHIEVEMENT SYSTEM
// ─────────────────────────────────────────────

model Quest {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   // DAILY, WEEKLY, ACHIEVEMENT
  category    String   // PREDICTION, FANTASY, COLLECTION, SOCIAL, GENERAL
  icon        String?
  targetCount Int      @default(1)
  rewardGp    Int      @default(50)
  isActive    Boolean  @default(true)

  userProgress UserQuestProgress[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 유저별 퀘스트 진행 상태 (daily/weekly는 periodKey로 구분)
model UserQuestProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId     String
  quest       Quest    @relation(fields: [questId], references: [id])

  progress    Int      @default(0)
  isCompleted Boolean  @default(false)
  isClaimed   Boolean  @default(false)
  // "2026-05-31" for DAILY, "2026-W22" for WEEKLY, "LIFETIME" for ACHIEVEMENT
  periodKey   String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, questId, periodKey])
}

model SystemLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// REAL LCK DATA (from Leaguepedia)
// ─────────────────────────────────────────────

// Series (BO3/BO5) level - one row per match
model LckRealMatch {
  id            String   @id @default(uuid())
  externalId    String   @unique // Leaguepedia MatchId (UniqueMatch)
  tournament    String   // "LCK/2026 Season/Spring Season"
  displayName   String?  // "LCK 2026 Spring"
  season        String   // "2026-SPRING"
  patch         String?

  team1         String   // team code, e.g. "T1"
  team2         String
  team1Name     String?  // full team name, e.g. "T1"
  team2Name     String?
  team1Logo     String?  // logo URL
  team2Logo     String?
  team1Score    Int      @default(0)
  team2Score    Int      @default(0)
  winner        String?  // team code of winner, null if not yet played

  bestOf        Int      @default(3)
  scheduledAt   DateTime?
  completedAt   DateTime?
  status        String   @default("SCHEDULED") // SCHEDULED, LIVE, COMPLETED

  games         LckGameStat[]
  lckPredictions LckPrediction[]

  syncedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 자주 쓰는 필터 조합에 인덱스 추가
  @@index([season, status])       // 시즌별 진행 중/완료 경기 조회
  @@index([season, scheduledAt])  // 시즌별 날짜 정렬
  @@index([scheduledAt])          // 전체 날짜 범위 조회
}

// Individual game within a series (Game 1, Game 2, ...)
model LckGameStat {
  id          String       @id @default(uuid())
  matchId     String
  match       LckRealMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  gameNumber  Int          // 1, 2, 3…
  winner      String?      // team code
  duration    String?      // "32:15"
  patch       String?

  playerStats LckPlayerGameStat[]

  createdAt   DateTime @default(now())

  @@unique([matchId, gameNumber])
}

// Per-player stat within a single game
model LckPlayerGameStat {
  id          String      @id @default(uuid())
  gameId      String
  game        LckGameStat @relation(fields: [gameId], references: [id], onDelete: Cascade)

  playerName  String
  team        String
  position    String?
  champion    String?

  kills       Int      @default(0)
  deaths      Int      @default(0)
  assists     Int      @default(0)
  cs          Int      @default(0)
  gold        Int      @default(0)
  damage      Int      @default(0)
  visionScore Int      @default(0)

  createdAt   DateTime @default(now())

  @@unique([gameId, playerName])
}

// ─────────────────────────────────────────────
// LCK 실제 경기 예측
// ─────────────────────────────────────────────

model LckPrediction {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId         String       // LckRealMatch.id
  match           LckRealMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  predictedWinner String       // team code e.g. "T1"
  predictedScore  String?      // "2:0" or "2:1" (null = 승팀만 예측)

  isProcessed     Boolean      @default(false)
  winnerCorrect   Boolean?     // 승팀 맞힘
  scoreCorrect    Boolean?     // 스코어도 맞힘
  isCorrect       Boolean?     // 전체 정답 여부 (= winnerCorrect)
  gpEarned        Int          @default(0)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([userId, matchId])
  @@index([isProcessed])  // 크론 정산: 미처리 예측 필터링
  @@index([matchId])      // 경기별 예측 집계
  @@index([userId])       // ✅ M-9 수정: 유저별 예측 내역 조회 최적화
}

// ─────────────────────────────────────────────
// DAILY QUIZ SYSTEM
// ─────────────────────────────────────────────

model DailyQuiz {
  id          String   @id @default(uuid())
  question    String
  optionA     String
  optionB     String
  optionC     String?
  optionD     String?
  answer      String   // "A", "B", "C", or "D"
  explanation String?  // 정답 해설 (정답 공개 후 표시)
  category    String   @default("TRIVIA") // TRIVIA, HISTORY, RULES, TEAMS
  difficulty  String   @default("NORMAL") // EASY, NORMAL, HARD
  gpReward    Int      @default(20)
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0) // 날짜별 순환 순서

  userAnswers UserDailyQuizAnswer[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 유저별 일별 퀴즈 응답 (하루 1회 제한)
model UserDailyQuizAnswer {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId         String
  quiz           DailyQuiz @relation(fields: [quizId], references: [id])
  dateKey        String    // "2026-05-31" - 하루 1번 제한 키

  selectedAnswer String    // "A", "B", "C", or "D"
  isCorrect      Boolean
  gpEarned       Int       @default(0)

  createdAt      DateTime  @default(now())

  @@unique([userId, dateKey]) // 하루에 한 번만
}

// Tracks the last time we synced from Leaguepedia
model DataSyncLog {
  id          String   @id @default(uuid())
  dataType    String   @unique // "LCK_MATCHES", "LCK_SCHEDULE", etc.
  lastSyncAt  DateTime @default(now())
  status      String   @default("OK") // OK, ERROR
  details     String?
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// COSMETICS SYSTEM
// ─────────────────────────────────────────────

// Catalogue of all cosmetic items
model CosmeticItem {
  id          String   @id @default(uuid())
  type        String   // TITLE, AVATAR, STICKER, PLAYER_CARD, PROFILE_FRAME, BACKGROUND
  name        String
  description String?
  rarity      String   @default("COMMON") // COMMON, UNCOMMON, RARE, EPIC, LEGENDARY
  imageUrl    String?
  gpCost      Int      @default(0) // 0 = not directly purchasable
  titleText   String?  // for TITLE type: the text shown on profile
  condition   String?  // how to unlock without shop: "TOP_100_RANK", "WIN_10_PREDICTIONS"
  isActive    Boolean  @default(true)

  userItems   UserCosmeticItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Items owned by a user
model UserCosmeticItem {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId      String
  item        CosmeticItem @relation(fields: [itemId], references: [id])

  obtainedBy  String   @default("SHOP") // SHOP, QUEST, FANTASY, ACHIEVEMENT, GACHA, EVENT
  isEquipped  Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@unique([userId, itemId])
}

// User's public profile / equipped cosmetics
model UserProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayTitle    String?  // equipped title text (denormalized for speed)
  equippedTitleId String?  // CosmeticItem id
  equippedAvatarId    String?
  equippedFrameId     String?
  equippedBackgroundId String?

  bio             String?
  favoriteTeam    String?  // team code

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────────────
// STICKERS (collection mini-feature)
// ─────────────────────────────────────────────

model Sticker {
  id          String   @id @default(uuid())
  name        String
  emoji       String?  // fallback emoji if no image
  imageUrl    String?
  rarity      String   @default("COMMON")
  relatedTeam String?  // team code
  relatedPlayer String?

  userStickers UserSticker[]

  createdAt   DateTime @default(now())
}

model UserSticker {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stickerId String
  sticker   Sticker  @relation(fields: [stickerId], references: [id])
  count     Int      @default(1) // duplicates stack

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, stickerId])
}

// ─────────────────────────────────────────────
// COMMUNITY (게시판)
// ─────────────────────────────────────────────

model Post {
  id        String   @id @default(uuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  title     String
  content   String   // 본문 (최대 5000자)
  category  String   @default("FREE") // FREE, ANALYSIS, PREDICTION, INFO

  viewCount Int      @default(0)
  isPinned  Boolean  @default(false)
  isDeleted Boolean  @default(false)

  comments  Comment[]
  likes     PostLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ M-9 수정: 커뮤니티 목록 정렬 최적화
  @@index([isDeleted, createdAt])
  @@index([category, createdAt])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content   String
  isDeleted Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostLike {
  postId    String
  post      Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([postId, userId])
}
