generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Custom Fields
  username      String?   // 기존 username 필드 유지 (선택적)
  points        Int       @default(0)
  gachaLevel    Int       @default(1)
  gachaExp      Int       @default(0)
  
  collection    UserCard[]
  myTeam        MyTeam?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  followedBy    Follows[] @relation("following")
  following     Follows[] @relation("follower")
}

model Follows {
  follower    User   @relation("follower", fields: [followerId], references: [id])
  followerId  String
  following   User   @relation("following", fields: [followingId], references: [id])
  followingId String

  @@id([followerId, followingId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Game Models
model Player {
  id            String    @id @default(uuid())
  name          String
  realName      String?
  team          String
  position      String
  seasonStats   String    // JSON string
  careerStats   String    // JSON string
  cost          Int       @default(10)
  cards         Card[]
  teamPlayers   TeamPlayer[]
}

model MyTeam {
  id            String    @id @default(uuid())
  userId        String    @unique // 1:1 관계
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  players       TeamPlayer[]
  totalCost     Int
  totalPoints   Int       @default(0)
  isFinalized   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TeamPlayer {
  id            String    @id @default(uuid())
  teamId        String
  team          MyTeam    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId      String
  player        Player    @relation(fields: [playerId], references: [id])
  position      String
}

model Card {
  id            String    @id @default(uuid())
  playerId      String
  player        Player    @relation(fields: [playerId], references: [id])
  season        String
  grade         String
  imageUrl      String?
  owners        UserCard[]
}

model UserCard {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId        String
  card          Card      @relation(fields: [cardId], references: [id])
  acquiredAt    DateTime  @default(now())
  isLocked      Boolean   @default(false)
}
