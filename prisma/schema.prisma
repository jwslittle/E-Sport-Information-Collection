generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Custom Fields
  username      String?   // 기존 username 필드 유지 (선택적)
  points        Int       @default(0)
  gachaLevel    Int       @default(1)
  gachaExp      Int       @default(0)
  
  collection    UserCard[]
  myTeam        MyTeam?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  followedBy    Follows[] @relation("following")
  following     Follows[] @relation("follower")

  quests        UserQuest[]
  achievements  UserAchievement[]
  
  auctions      Auction[] @relation("Seller")
  bids          Bid[]
  winningBids   Auction[] @relation("Bidder")
}

model Follows {
  follower    User   @relation("follower", fields: [followerId], references: [id])
  followerId  String
  following   User   @relation("following", fields: [followingId], references: [id])
  followingId String

  @@id([followerId, followingId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Game Models
model Player {
  id            String    @id @default(uuid())
  name          String
  realName      String?
  team          String
  position      String
  seasonStats   String    // JSON string
  careerStats   String    // JSON string
  cost          Int       @default(10)
  cards         Card[]
  teamPlayers   TeamPlayer[]
}

model MyTeam {
  id            String    @id @default(uuid())
  userId        String    @unique // 1:1 관계
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  players       TeamPlayer[]
  totalCost     Int
  totalPoints   Int       @default(0)
  isFinalized   Boolean   @default(false) // Legacy, use lastFinalizedRound
  lastFinalizedRound Int  @default(-1)
  roundScores   MyTeamRoundScore[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TeamPlayer {
  id            String    @id @default(uuid())
  teamId        String
  team          MyTeam    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId      String
  player        Player    @relation(fields: [playerId], references: [id])
  position      String
  isStarter     Boolean   @default(true)
}

model Card {
  id            String    @id @default(uuid())
  playerId      String
  player        Player    @relation(fields: [playerId], references: [id])
  season        String
  grade         String
  imageUrl      String?
  owners        UserCard[]
}

model UserCard {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId        String
  card          Card      @relation(fields: [cardId], references: [id])
  acquiredAt    DateTime  @default(now())
  isLocked      Boolean   @default(false)
  auction       Auction?
}

// Quest & Achievement Models
model Quest {
  id           String      @id @default(uuid())
  title        String
  description  String
  type         String      // DAILY, WEEKLY
  actionType   String      // SIMULATION_PLAY, CARD_COLLECT, etc.
  targetCount  Int
  rewardPoints Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  userQuests   UserQuest[]
}

model UserQuest {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId     String
  quest       Quest     @relation(fields: [questId], references: [id])
  progress    Int       @default(0)
  isCompleted Boolean   @default(false)
  isClaimed   Boolean   @default(false)
  resetAt     DateTime? // 다음 리셋 시간
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, questId])
}

model Achievement {
  id               String            @id @default(uuid())
  title            String
  description      String
  actionType       String
  targetCount      Int
  rewardPoints     Int
  icon             String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userAchievements UserAchievement[]
}

model Auction {
  id              String    @id @default(uuid())
  sellerId        String
  seller          User      @relation("Seller", fields: [sellerId], references: [id])
  cardId          String    @unique // 한 카드는 하나의 경매만 가능
  card            UserCard  @relation(fields: [cardId], references: [id])
  minPrice        Int
  currentPrice    Int
  highestBidderId String?
  highestBidder   User?     @relation("Bidder", fields: [highestBidderId], references: [id])
  endTime         DateTime
  status          String    @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED, EXPIRED
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  bids            Bid[]
}

model Bid {
  id        String   @id @default(uuid())
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidderId  String
  bidder    User     @relation(fields: [bidderId], references: [id])
  amount    Int
  createdAt DateTime @default(now())
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  progress      Int         @default(0)
  isCompleted   Boolean     @default(false)
  isClaimed     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([userId, achievementId])
}

model GameState {
  id            String   @id @default(uuid())
  currentRound  Int      @default(0)
  seasonYear    Int      @default(2024)
  isRoundActive Boolean  @default(false) // If true, roster changes are locked
  nextMatchDate DateTime @default(now())
  upcomingMatches String? // JSON string: [{team1: string, team2: string}]
  updatedAt     DateTime @updatedAt
}

model MatchLog {
  id        String   @id @default(uuid())
  round     Int
  team1     String
  team2     String
  winner    String
  details   String   // JSON string of player stats
  createdAt DateTime @default(now())
}

model MyTeamRoundScore {
  id        String   @id @default(uuid())
  teamId    String
  team      MyTeam   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  round     Int
  points    Int
  details   String   // JSON: { playerId: points, ... }
  createdAt DateTime @default(now())
}

